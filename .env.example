
NODE_ENV=development
PORT=5000

PROJECT_NAME=my-new-project

MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>.mongodb.net

# ---- Redis (used for login rate limiting + refresh-token blacklist) ----
# Use a Redis Cloud / Upstash / local Redis instance.
REDIS_URI=redis://default:password@localhost:6379

# ---- JWT ----
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ---- Cookies ----
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ---- CORS ----
# Comma separated list of allowed origins (your frontend apps)
CLIENT_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Email (Nodemailer — used for verification & password reset) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Auth Service <no-reply@yourapp.com>"

# ---- Rate Limiting ----
# Login attempts allowed per IP+email combo within the window
LOGIN_RATE_LIMIT_POINTS=5
LOGIN_RATE_LIMIT_DURATION_SECONDS=900
LOGIN_RATE_LIMIT_BLOCK_SECONDS=900

# General API rate limit (per IP)
API_RATE_LIMIT_POINTS=100
API_RATE_LIMIT_DURATION_SECONDS=60

# ---- Frontend URLs used inside emails ----
CLIENT_VERIFY_EMAIL_URL=http://localhost:3000/verify-email
CLIENT_RESET_PASSWORD_URL=http://localhost:3000/reset-password

# ---- Admin bootstrap (optional, used by `npm run seed:admin`) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Super Admin
